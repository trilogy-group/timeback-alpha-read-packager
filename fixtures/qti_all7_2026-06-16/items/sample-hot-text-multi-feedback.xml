<?xml version='1.0' encoding='UTF-8'?>
<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd" identifier="sample-hot-text-multi-feedback" title="HotTextInteraction" adaptive="false" time-dependent="false" tool-name="incept-qti-sdk" tool-version="0.5.7">
  <qti-response-declaration identifier="RESPONSE" cardinality="multiple" base-type="identifier">
    <qti-correct-response>
      <qti-value>w2</qti-value>
      <qti-value>w6</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float" normal-maximum="1.0">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-outcome-declaration identifier="MAXSCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>1.0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-outcome-declaration identifier="FEEDBACK" cardinality="single" base-type="identifier"/>
  <qti-item-body>
    <div class="stem">
      <p>Select the <strong>two nouns</strong> in the sentence.</p>
    </div>
    <qti-hottext-interaction response-identifier="RESPONSE" max-choices="2" min-choices="2">
      <p>The <qti-hottext identifier="w2">dog</qti-hottext> <qti-hottext identifier="w3">quickly</qti-hottext> <qti-hottext identifier="w4">chased</qti-hottext> the <qti-hottext identifier="w6">ball</qti-hottext> <qti-hottext identifier="w7">outside</qti-hottext>.</p>
    </qti-hottext-interaction>
    <qti-feedback-block identifier="correct" outcome-identifier="FEEDBACK" show-hide="show">
      <qti-content-body>
        <div class="qti-feedback-correct">
          <p><strong>Correct!</strong> "Dog" and "ball" are both nouns — they name a person/animal and a thing.</p>
        </div>
      </qti-content-body>
    </qti-feedback-block>
    <qti-feedback-block identifier="incorrect" outcome-identifier="FEEDBACK" show-hide="show">
      <qti-content-body>
        <div class="qti-feedback-incorrect">
          <p>Nouns name people, animals, places, or things. Look for the animal and the object in the sentence.</p>
        </div>
      </qti-content-body>
    </qti-feedback-block>
  </qti-item-body>
  <qti-response-processing>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-correct identifier="RESPONSE"/>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-base-value base-type="float">1</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">correct</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-if>
      <qti-response-else>
        <qti-set-outcome-value identifier="SCORE">
          <qti-base-value base-type="float">0</qti-base-value>
        </qti-set-outcome-value>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">incorrect</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else>
    </qti-response-condition>
  </qti-response-processing>
</qti-assessment-item>
