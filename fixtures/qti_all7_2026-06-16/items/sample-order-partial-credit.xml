<?xml version='1.0' encoding='UTF-8'?>
<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd" identifier="sample-order-partial-credit" title="OrderInteraction" adaptive="false" time-dependent="false" tool-name="incept-qti-sdk" tool-version="0.5.7">
  <qti-response-declaration identifier="RESPONSE" cardinality="ordered" base-type="identifier">
    <qti-correct-response>
      <qti-value>question</qti-value>
      <qti-value>hypothesis</qti-value>
      <qti-value>experiment</qti-value>
      <qti-value>analyze</qti-value>
      <qti-value>conclude</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float" normal-maximum="5.0">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-outcome-declaration identifier="MAXSCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>5.0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-outcome-declaration identifier="FEEDBACK" cardinality="single" base-type="identifier"/>
  <qti-outcome-declaration identifier="MODAL_FEEDBACK" cardinality="single" base-type="identifier"/>
  <qti-item-body>
    <div class="stem">
      <p>Drag the steps of the scientific method into the correct order.</p>
    </div>
    <qti-order-interaction response-identifier="RESPONSE" shuffle="true">
      <qti-simple-choice identifier="question">
        <p>Ask a question</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="hypothesis">
        <p>Form a hypothesis</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="experiment">
        <p>Conduct an experiment</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="analyze">
        <p>Analyze the results</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="conclude">
        <p>Draw a conclusion</p>
      </qti-simple-choice>
    </qti-order-interaction>
  </qti-item-body>
  <qti-response-processing>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-index n="1">
            <qti-variable identifier="RESPONSE"/>
          </qti-index>
          <qti-base-value base-type="identifier">question</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-sum>
            <qti-variable identifier="SCORE"/>
            <qti-base-value base-type="float">1</qti-base-value>
          </qti-sum>
        </qti-set-outcome-value>
      </qti-response-if>
    </qti-response-condition>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-index n="2">
            <qti-variable identifier="RESPONSE"/>
          </qti-index>
          <qti-base-value base-type="identifier">hypothesis</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-sum>
            <qti-variable identifier="SCORE"/>
            <qti-base-value base-type="float">1</qti-base-value>
          </qti-sum>
        </qti-set-outcome-value>
      </qti-response-if>
    </qti-response-condition>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-index n="3">
            <qti-variable identifier="RESPONSE"/>
          </qti-index>
          <qti-base-value base-type="identifier">experiment</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-sum>
            <qti-variable identifier="SCORE"/>
            <qti-base-value base-type="float">1</qti-base-value>
          </qti-sum>
        </qti-set-outcome-value>
      </qti-response-if>
    </qti-response-condition>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-index n="4">
            <qti-variable identifier="RESPONSE"/>
          </qti-index>
          <qti-base-value base-type="identifier">analyze</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-sum>
            <qti-variable identifier="SCORE"/>
            <qti-base-value base-type="float">1</qti-base-value>
          </qti-sum>
        </qti-set-outcome-value>
      </qti-response-if>
    </qti-response-condition>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-index n="5">
            <qti-variable identifier="RESPONSE"/>
          </qti-index>
          <qti-base-value base-type="identifier">conclude</qti-base-value>
        </qti-match>
        <qti-set-outcome-value identifier="SCORE">
          <qti-sum>
            <qti-variable identifier="SCORE"/>
            <qti-base-value base-type="float">1</qti-base-value>
          </qti-sum>
        </qti-set-outcome-value>
      </qti-response-if>
    </qti-response-condition>
    <qti-response-condition>
      <qti-response-if>
        <qti-match>
          <qti-variable identifier="RESPONSE"/>
          <qti-correct identifier="RESPONSE"/>
        </qti-match>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">correct</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-if>
      <qti-response-else>
        <qti-set-outcome-value identifier="FEEDBACK">
          <qti-base-value base-type="identifier">incorrect</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else>
    </qti-response-condition>
    <qti-response-condition>
      <qti-response-if>
        <qti-gte>
          <qti-variable identifier="SCORE"/>
          <qti-variable identifier="MAXSCORE"/>
        </qti-gte>
        <qti-set-outcome-value identifier="MODAL_FEEDBACK">
          <qti-base-value base-type="identifier">modal_feedback_correct</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-if>
      <qti-response-else-if>
        <qti-gt>
          <qti-variable identifier="SCORE"/>
          <qti-base-value base-type="float">0</qti-base-value>
        </qti-gt>
        <qti-set-outcome-value identifier="MODAL_FEEDBACK">
          <qti-base-value base-type="identifier">modal_feedback_partial</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else-if>
      <qti-response-else>
        <qti-set-outcome-value identifier="MODAL_FEEDBACK">
          <qti-base-value base-type="identifier">modal_feedback_incorrect</qti-base-value>
        </qti-set-outcome-value>
      </qti-response-else>
    </qti-response-condition>
  </qti-response-processing>
  <qti-modal-feedback outcome-identifier="MODAL_FEEDBACK" identifier="modal_feedback_correct" show-hide="show">
    <qti-content-body>
      <div>
        <p><strong>Correct!</strong> That is the standard order of the scientific method.</p>
      </div>
    </qti-content-body>
  </qti-modal-feedback>
  <qti-modal-feedback outcome-identifier="MODAL_FEEDBACK" identifier="modal_feedback_incorrect" show-hide="show">
    <qti-content-body>
      <div>
        <p>The scientific method always starts with asking a question and ends with a conclusion.</p>
      </div>
    </qti-content-body>
  </qti-modal-feedback>
</qti-assessment-item>
